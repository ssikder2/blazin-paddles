{
  "name": "@repo/database",
  "version": "0.0.0",
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "analyze": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "build": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --config prisma.config.ts",
    "db:generate": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "db:setup": "node scripts/setup-db.mjs",
    "db:verify": "node scripts/verify-db.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@prisma/client-runtime-utils": "^7.4.2",
    "@t3-oss/env-nextjs": "^0.13.10",
    "pg": "^8.16.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "25.5.2",
    "@types/pg": "^8.15.5",
    "dotenv": "^16.5.0",
    "prisma": "7.4.2",
    "typescript": "^5.9.3"
  }
}
