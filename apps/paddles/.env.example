# Supabase → Project Settings → API (Project URL + anon public JWT, starts with eyJ…).
# Prefer `apps/paddles/.env.local`, or a parent-folder `.env.local` (monorepo root / folder above it).
#
# Vercel Supabase integration often injects these names instead:
# SUPABASE_URL, SUPABASE_ANON_KEY — they are mapped automatically in next.config.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
