{
  "name": "next-forge",
  "version": "6.0.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel/next-forge.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "bin": {
    "next-forge": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "turbo test",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "bump-deps": "bunx npm-check-updates --deep -u && bun install",
    "bump-ui": "bunx shadcn@latest add --all --overwrite -c packages/design-system",
    "migrate": "cd packages/database && bunx prisma format && bunx prisma generate --schema=./prisma/schema.prisma && bunx prisma migrate dev --config prisma.config.ts",
    "migrate:deploy": "cd packages/database && bunx prisma generate --schema=./prisma/schema.prisma && bunx prisma migrate deploy --config prisma.config.ts",
    "db:push": "cd packages/database && bunx prisma format && bunx prisma generate --schema=./prisma/schema.prisma && bunx prisma db push --config prisma.config.ts",
    "db:setup": "npm run db:setup --workspace=@repo/database",
    "db:verify": "npm run db:verify --workspace=@repo/database",
    "clean": "git clean -xdf node_modules",
    "release": "npm publish"
  },
  "devDependencies": {
    "@auto-it/first-time-contributor": "^11.3.6",
    "@biomejs/biome": "2.4.6",
    "@repo/typescript-config": "*",
    "@turbo/gen": "^2.8.14",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.8.1",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3",
    "nypm": "^0.6.5"
  },
  "overrides": {
    "parse5": "^7.2.1"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
